    "answerLatex": "2(\\sqrt{2}-1)",
    "method": "area-entre-curvas",
    "hints": [
      "Encuentra dónde se cruzan: \\(\\sin x = \\cos x \\Rightarrow x=\\pi/4\\)",
      "En \\([0,\\pi/4]\\): \\(\\cos x \\geq \\sin x\\)",
      "En \\([\\pi/4, \\pi/2]\\): \\(\\sin x \\geq \\cos x\\)"
    ],
    "commonMistakes": ["No dividir el intervalo en el punto de cruce"],
    "steps": [
      "A = \\int_0^{\\pi/4}(\\cos x-\\sin x)\\,dx + \\int_{\\pi/4}^{\\pi/2}(\\sin x-\\cos x)\\,dx",
      "= [\\sin x+\\cos x]_0^{\\pi/4} + [-\\cos x-\\sin x]_{\\pi/4}^{\\pi/2}",
      "= (\\sqrt{2}-1) + (-(0+1)+\\sqrt{2})",
      "= (\\sqrt{2}-1) + (\\sqrt{2}-1) = 2(\\sqrt{2}-1)"
    ]
  }
